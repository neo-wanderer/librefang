g_memory::MemorySubstrate::open_in_memory(0.01).unwrap();\n        let agent_id = librefang_types::agent::AgentId::new();\n        let mut session = librefang_memory::session::Session {\n            id: librefang_types::agent::SessionId::new(),\n            agent_id,\n            messages: Vec::new(),\n            context_window_tokens: 0,\n            label: None,\n        };\n        let manifest = test_manifest();\n        let driver: Arc<dyn LlmDriver> = Arc::new(AlwaysFailingToolDriver);\n\n        let err = run_agent_loop(\n            &manifest, \"Do something\", &mut session, &memory, driver, &[],\n            None, None, None, None, None, None, None, None, None, None,\n            None, None, None, None, None, None, None, None, None, None,\n        )\n        .await\n        .expect_err(\"Loop must exit with RepeatedToolFailures\");\n\n        match err {\n            LibreFangError::RepeatedToolFailures { iterations, .. } => {\n                assert_eq!(iterations, 3, \"Cap should trigger after 3 consecutive all-failed iterations\");\n            }\n            other => panic!(\"Expected RepeatedToolFailures, got {other:?}\"),\n        }\n    }\n```\n\n- [ ] **Step 7: Run the new tests**\n\nRun: `cargo test -p librefang-runtime --lib test_tool_failure_allows_retry_on_next_iteration test_repeated_tool_failures_cap_exits_loop -- --nocapture`\nExpected: Both PASS.\n\n- [ ] **Step 8: Run the full runtime test suite**\n\nRun: `cargo test -p librefang-runtime --lib`\nExpected: All pass (no regressions).\n\n- [ ] **Step 9: Commit**\n\n```bash\ngit add crates/librefang-runtime/src/agent_loop.rs\ngit commit -m \"feat(runtime): cap consecutive tool failures at 3 iterations\"\n```\n\n---\n\n### Task 3: Mirror cap logic in streaming path\n\n**Files:**\n- Modify: `crates/librefang-runtime/src/agent_loop.rs:3078`\n\n- [ ] **Step 1: Declare the counter in streaming loop**\n\nFind line 2297 (`for iteration in 0..max_iterations {` inside `run_agent_loop_streaming`). Direc