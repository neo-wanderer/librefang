#!/usr/bin/env bash
set -euo pipefail

ENV_FILE="${LIBREFANG_DOCKER_ENV:-/etc/librefang/docker.env}"

if [[ -f "$ENV_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$ENV_FILE"
fi

IMAGE="${LIBREFANG_DOCKER_IMAGE:-ghcr.io/librefang/librefang:2026.6.24-beta.23}"
CONTAINER_NAME="${LIBREFANG_DOCKER_NAME:-librefang}"
DATA_VOLUME="${LIBREFANG_DOCKER_DATA_VOLUME:-librefang-data}"
PORT="${LIBREFANG_DOCKER_PORT:-4545}"

docker_args=(
  --name "$CONTAINER_NAME"
  --publish "127.0.0.1:${PORT}:4545"
  --volume "${DATA_VOLUME}:/data"
  --env "LIBREFANG_LISTEN=0.0.0.0:4545"
)

append_env_if_set() {
  local name="$1"
  if [[ -n "${!name:-}" ]]; then
    docker_args+=(--env "${name}=${!name}")
  fi
}

append_known_provider_env() {
  append_env_if_set OPENAI_API_KEY
  append_env_if_set ANTHROPIC_API_KEY
  append_env_if_set GROQ_API_KEY
  append_env_if_set TELEGRAM_BOT_TOKEN
  append_env_if_set DISCORD_BOT_TOKEN
  append_env_if_set SLACK_BOT_TOKEN
  append_env_if_set SLACK_APP_TOKEN
  append_env_if_set LIBREFANG_ALLOW_NO_AUTH
}

usage() {
  cat <<EOF
Usage: librefang-docker <command>

Commands:
  run       Pull and run the pinned LibreFang image in the foreground
  start     Pull and run the pinned LibreFang image in the background
  stop      Stop and remove the managed container
  pull      Pull the pinned LibreFang image
  logs      Follow logs for the managed container
  status    Show the managed container status
  shell     Open a shell in the managed container
EOF
}

cmd="${1:-run}"
case "$cmd" in
  run)
    append_known_provider_env
    docker pull "$IMAGE"
    docker rm -f "$CONTAINER_NAME" >/dev/null 2>&1 || true
    exec docker run --rm "${docker_args[@]}" "$IMAGE"
    ;;
  start)
    append_known_provider_env
    docker pull "$IMAGE"
    docker rm -f "$CONTAINER_NAME" >/dev/null 2>&1 || true
    docker run --detach --restart unless-stopped "${docker_args[@]}" "$IMAGE"
    ;;
  stop)
    docker rm -f "$CONTAINER_NAME"
    ;;
  pull)
    docker pull "$IMAGE"
    ;;
  logs)
    docker logs --follow "$CONTAINER_NAME"
    ;;
  status)
    docker ps --all --filter "name=^/${CONTAINER_NAME}$"
    ;;
  shell)
    exec docker exec -it "$CONTAINER_NAME" /bin/sh
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
