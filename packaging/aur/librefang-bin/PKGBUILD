pkgname=librefang-bin
_pkgname=librefang
pkgver=2026.6.24_beta.23
_upstream_ver=${pkgver/_/-}
pkgrel=1
pkgdesc="Community-maintained Agent Operating System written in Rust"
arch=('x86_64')
url="https://librefang.ai"
license=('MIT')
depends=('gcc-libs' 'glibc' 'dbus')
optdepends=(
  'python: first-party channel sidecar adapters'
  'docker: Docker-backed tools and sandbox workflows'
)
provides=('librefang')
conflicts=('librefang')
backup=('etc/librefang/env')
install="${pkgname}.install"
options=('!debug')
source=(
  "https://github.com/librefang/librefang/releases/download/v${_upstream_ver}/librefang-x86_64-unknown-linux-gnu.tar.gz"
  "LICENSE::https://raw.githubusercontent.com/librefang/librefang/v${_upstream_ver}/LICENSE"
  "librefang.service"
  "librefang.sysusers"
  "librefang.tmpfiles"
  "librefang.env"
)
sha256sums=(
  'c81a5d2b1b904e2f0864534c30c01e9cbe36b1e6790c419414e2684dd501a516'
  'd4330a3004bd990da1830124b1ccccb51129ebb8b5a70a0b79d5626b7c1226a0'
  '8256e3089819a4e4a865c5454876fdf3192945c9569b85d6854a31c3b3ee911f'
  '9d72d1f4de5e5aef909778d7ccb9de3c29072ed1dc371a252b551b828e5a74d9'
  'd5551061bab4c176c95ea77d4c787c3f766f64a78fe0937b9a857f07073bd59e'
  'e6c162276a58e632cd7464629c39a24671d8bacf953cb4b0261bad6efb145d24'
)

package() {
  install -Dm755 "$srcdir/librefang" "$pkgdir/usr/bin/librefang"

  if [[ -f "$srcdir/librefang-sidecar-telegram" ]]; then
    install -Dm755 "$srcdir/librefang-sidecar-telegram" "$pkgdir/usr/bin/librefang-sidecar-telegram"
  fi

  install -Dm644 "$srcdir/LICENSE" "$pkgdir/usr/share/licenses/${pkgname}/LICENSE"
  install -Dm644 "$srcdir/librefang.service" "$pkgdir/usr/lib/systemd/system/librefang.service"
  install -Dm644 "$srcdir/librefang.sysusers" "$pkgdir/usr/lib/sysusers.d/librefang.conf"
  install -Dm644 "$srcdir/librefang.tmpfiles" "$pkgdir/usr/lib/tmpfiles.d/librefang.conf"
  install -Dm644 "$srcdir/librefang.env" "$pkgdir/etc/librefang/env"
}
